{
  "contracts_dir": "stellar-insured-contracts/contracts",
  "timeout": 300,
  "max_depth": 10,
  "checks": [
    "reentrancy",
    "overflow",
    "access_control",
    "unauthorized_payout",
    "unauthorized_state_mutation"
  ],
  "symbolic_engine": "z3",
  "output_format": "json",
  "ci_failure_threshold": {
    "critical": 0,
    "high": 0
  },
  "patterns": {
    "unauthorized_payout": [
      "transfer(",
      "payable(",
      "send(",
      "payout(",
      "withdraw("
    ],
    "unauthorized_state_mutation": [
      ".set(",
      ".update(",
      ".modify(",
      "storage.",
      "env.storage."
    ]
  },
  "invariants": [
    "no_unauthorized_payout",
    "no_unauthorized_state_mutation",
    "pool_balance_integrity",
    "policy_fund_locking",
    "claim_uniqueness",
    "governance_quorum",
    "slashing_proportionality"
  ]
}
