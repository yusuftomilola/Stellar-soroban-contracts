{
  "timeout_seconds": 300,
  "max_depth": 50,
  "check_reentrancy": true,
  "check_overflow": true,
  "check_access_control": true,
  "symbolic_engine": "corral",
  "contracts_dir": "stellar-insured-contracts/contracts",
  "invariants_file": "invariants.json",
  "output_format": "json",
  "fail_on_critical": true,
  "fail_on_high": true,
  "security_checks": {
    "unauthorized_payout": {
      "enabled": true,
      "patterns": [
        "transfer_payment",
        "pay",
        "payout",
        "withdraw",
        "send_payment"
      ],
      "required_auth": [
        "require_auth",
        "require_role",
        "require_admin",
        "has_role",
        "authorize"
      ]
    },
    "unauthorized_state_mutation": {
      "enabled": true,
      "critical_state_keys": [
        "admin",
        "owner", 
        "config",
        "policy",
        "claim",
        "pool",
        "treasury"
      ]
    },
    "reentrancy": {
      "enabled": true,
      "external_call_patterns": [
        "env.invoke_contract",
        "call",
        "invoke"
      ]
    },
    "integer_overflow": {
      "enabled": true,
      "arithmetic_patterns": [
        "+",
        "-",
        "*",
        "/"
      ]
    }
  }
}
